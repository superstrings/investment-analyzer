# Investment Analyzer Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# Database Configuration
# ============================================================
DATABASE_URL=postgresql://localhost:5432/investment_db

# ============================================================
# Futu OpenD Configuration
# ============================================================
# Default Futu OpenD connection (localhost)
FUTU_OPEND_HOST=127.0.0.1
FUTU_OPEND_PORT=11111

# Trade passwords per user (format: FUTU_PWD_{USERNAME})
FUTU_PWD_DYSON=your_trade_password_here

# ============================================================
# Web Server (FastAPI)
# ============================================================
WEB_HOST=0.0.0.0
WEB_PORT=8000
# Login credentials for web UI
WEB_USERNAME=dyson
WEB_PASSWORD=your_password_here
# Internal session token stored in cookie (leave empty to disable auth)
WEB_AUTH_TOKEN=your_secure_token_here
# Default user for web operations
WEB_DEFAULT_USER=dyson
# External URL for links in DingTalk messages (optional)
WEB_BASE_URL=https://inv.runwith.top

# ============================================================
# DingTalk Bot (optional)
# ============================================================
DINGTALK_ENABLED=false
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN
DINGTALK_SECRET=YOUR_SECRET

# ============================================================
# Proxy (optional, for akshare if needed)
# ============================================================
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ============================================================
# Application Settings
# ============================================================
LOG_LEVEL=INFO
# DB_ECHO=true  # Enable SQL query logging
